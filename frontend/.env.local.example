# Copy this file to `.env.local` and fill in your values.

# Deployed SkyShield AI contract address (0x-prefixed).
# Defaults to the live studionet deployment when unset.
NEXT_PUBLIC_SKYSHIELD_CONTRACT_ADDRESS=0x91dCD64Fa828b5003688de07C6DCf052cF75E931

# Target GenLayer network. One of: studionet | localnet | testnetAsimov | testnetBradbury
# studionet RPC: https://studio.genlayer.com/api
NEXT_PUBLIC_GENLAYER_CHAIN=studionet
